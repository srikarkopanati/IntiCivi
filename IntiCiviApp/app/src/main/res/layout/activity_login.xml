<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@color/blue"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Emblem -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_emblem" />

        <!-- Title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="National Civic"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Issue Portal"
                android:textColor="#FFA726"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>


        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="GOVERNMENT OF INDIA"
            android:textColor="#DDFFFFFF"
            android:textSize="12sp" />

        <!-- Small color bar -->

    </LinearLayout>

    <!-- 🇮🇳 TRICOLOR STRIP -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_below="@id/header"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#FF9933" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#FFFFFF" />

        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#138808" />
    </LinearLayout>

    <!-- CARD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_marginTop="60dp"
        android:layout_marginLeft="24dp"
        android:layout_marginRight="24dp"
        android:background="@drawable/card_bg"
        android:elevation="10dp"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ICON -->
        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:background="@drawable/ic_user"
            android:padding="18dp"
             />

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Citizen Login"
            android:textColor="@color/blue"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Enter your phone number to continue"
            android:textColor="#666"
            android:textStyle="bold"
            android:textSize="18sp" />

        <!-- PHONE INPUT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@drawable/phone_input_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <!-- Country Code -->
            <TextView
                android:text="+91"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"
                android:paddingEnd="10dp"/>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="25dp"
                android:background="#CCCCCC"/>

            <!-- Phone Input -->
            <EditText
                android:id="@+id/et_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Phone Number"
                android:inputType="phone"
                android:maxLength="10"
                android:textSize="18dp"
                android:paddingStart="10dp"
                android:background="@android:color/transparent"/>
        </LinearLayout>

        <!-- CONTINUE BUTTON -->
        <Button
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#1A237E"
            android:text="Continue"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <!-- GOOGLE BUTTON -->
        <Button
            android:id="@+id/btn_google"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="Continue with Google"
            android:textAllCaps="false"
            android:backgroundTint="#FFFFFF"
            app:strokeColor="#DDDDDD"
            app:strokeWidth="1dp"
            android:textColor="#000000"
            android:drawableLeft="@drawable/ic_google"
            android:drawablePadding="12dp"
            android:paddingStart="16dp"/>

    </LinearLayout>

</RelativeLayout>