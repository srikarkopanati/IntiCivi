<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:background="#0E2B54"
    android:fitsSystemWindows="true"
    android:padding="8dp"
    >

    <!-- Left Logo (Ashoka Emblem) -->
    <ImageView
        android:id="@+id/imgEmblem"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_emblem"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Center Title -->
    <LinearLayout
        android:id="@+id/titleLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toEndOf="@id/imgEmblem"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:padding="8dp"
        tools:ignore="NotSibling">

        <TextView
            android:text="National Civic Issue Portal"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#000000"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"/>

        <TextView
            android:text="Government of India"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:textSize="14sp"
            android:textColor="#555555"/>
    </LinearLayout>

    <!-- Right Side (Flag + Logo) -->
    <LinearLayout
        android:id="@+id/rightLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
