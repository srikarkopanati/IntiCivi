              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "admin", "users", "{{userId}}", "role"]
            }
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/admin/users/{{userId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "admin", "users", "{{userId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "admin_jwt_token_here",
      "type": "string"
    },
    {
      "key": "complaintId",
      "value": "mongodb_object_id_here",
